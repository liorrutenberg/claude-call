{
  "name": "claude-call",
  "version": "0.1.0",
  "description": "Continuous two-way voice conversations for Claude Code",
  "type": "module",
  "main": "dist/channel.js",
  "bin": {
    "claude-call": "dist/cli.js"
  },
  "files": [
    "dist",
    "config",
    "skills",
    "plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.tui.json",
    "dev": "tsc --watch",
    "install:call": "node dist/cli.js install",
    "init": "node dist/cli.js init",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tui.json"
  },
  "keywords": [
    "claude",
    "claude-code",
    "voice",
    "tts",
    "stt",
    "mcp",
    "channel",
    "hands-free",
    "speech"
  ],
  "author": "Lior Rutenberg",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/liorrutenberg/claude-call.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ink": "^5.1.0",
    "onnxruntime-node": "^1.21.0",
    "react": "^18.3.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.18",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "sherpa-onnx-node": "^1.12.0"
  }
}
