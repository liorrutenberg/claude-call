#!/usr/bin/env bash
# eldc — Claude Code with voice call session (continue last conversation)
# Equivalent to cld --continue + voice

claude-call call start 2>/dev/null
trap "claude-call call stop 2>/dev/null" EXIT INT TERM
CLAUDE_CALL=1 claude --dangerously-skip-permissions --dangerously-load-development-channels server:call-display --continue "$@"
