#!/usr/bin/env bash
# eldr — Claude Code with voice call session (resume last conversation)
# Equivalent to cld --resume + voice

OUTPUT=$(claude-call call start 2>&1)
echo "$OUTPUT"
PID=$(echo "$OUTPUT" | grep -o 'PID [0-9]*' | grep -o '[0-9]*')
trap "claude-call call stop --if-pid $PID 2>/dev/null" EXIT INT TERM
CLAUDE_CALL=1 claude --dangerously-skip-permissions --dangerously-load-development-channels server:call-display --resume "$@"
